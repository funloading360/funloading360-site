# ──────────────────────────────────────────────────────────────
# FunLoading360 — Environment Variables Configuration
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# Email & Communication (REQUIRED)
# ──────────────────────────────────────────────────────────────

# Resend API — email delivery for booking confirmations
# Register at https://resend.com/api-keys to get your key
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Admin email for booking inquiries and quotes
# All booking requests are sent to this email address
CONTACT_EMAIL=hello@funloading360.co.uk

# ──────────────────────────────────────────────────────────────
# Rate Limiting & Caching (REQUIRED)
# ──────────────────────────────────────────────────────────────

# Upstash Redis — rate limiting for /api/book endpoint
# Prevents abuse: max 5 requests per 10 minutes per IP
# Sign up at https://upstash.com to get REST URL & token
UPSTASH_REDIS_REST_URL=https://your-workspace.upstash.io

UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# ──────────────────────────────────────────────────────────────
# Analytics (Optional, hardcoded in code)
# ──────────────────────────────────────────────────────────────

# Google Analytics 4 — currently hardcoded as G-0ZFCDKRLJZ
# To make configurable, uncomment and update GoogleAnalytics.tsx
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────────
# SMS & Automation (Optional, Phase 2)
# ──────────────────────────────────────────────────────────────

# Twilio SMS — booking confirmations (Phase 2)
# Uncomment when ready to send SMS confirmations
# Sign up at https://www.twilio.com to get credentials
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# Zapier Webhook — automatic PDF quote generation (Phase 1B async)
# Trigger quote template when booking is submitted
# Create a Zapier webhook at https://zapier.com/app/zaps
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxx/yyy

# ──────────────────────────────────────────────────────────────
# Stripe Payment Processing (Optional, Phase 2)
# ──────────────────────────────────────────────────────────────

# Stripe — 15% deposit collection (Phase 2, deferred)
# Sign up at https://stripe.com and get your API keys
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ──────────────────────────────────────────────────────────────
# Google Calendar Integration (Optional, Phase 2)
# ──────────────────────────────────────────────────────────────

# Google Calendar OAuth2 — real-time availability (Phase 2)
# Setup OAuth2 credentials at https://console.cloud.google.com
# GOOGLE_CALENDAR_API_KEY=your_api_key
# GOOGLE_CALENDAR_ID=raz@example.com
# GOOGLE_CALENDAR_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CALENDAR_CLIENT_SECRET=your_client_secret
