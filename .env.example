# ──────────────────────────────────────────────────────────────
# FunLoading360 — Environment Variables Configuration
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# Email & Communication (REQUIRED)
# ──────────────────────────────────────────────────────────────

# Resend API — email delivery for booking confirmations
# Register at https://resend.com/api-keys to get your key
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Admin email for booking inquiries and quotes
# All booking requests are sent to this email address
CONTACT_EMAIL=hello@funloading360.co.uk

# ──────────────────────────────────────────────────────────────
# Rate Limiting & Caching (REQUIRED)
# ──────────────────────────────────────────────────────────────

# Upstash Redis — rate limiting for /api/book endpoint
# Prevents abuse: max 5 requests per 10 minutes per IP
# Sign up at https://upstash.com to get REST URL & token
UPSTASH_REDIS_REST_URL=https://your-workspace.upstash.io

UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# ──────────────────────────────────────────────────────────────
# Analytics (Optional, hardcoded in code)
# ──────────────────────────────────────────────────────────────

# Google Analytics 4 — currently hardcoded as G-0ZFCDKRLJZ
# To make configurable, uncomment and update GoogleAnalytics.tsx
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────────────────────
# SMS & Automation (Optional, Phase 2)
# ──────────────────────────────────────────────────────────────

# Twilio SMS — booking confirmations (Phase 2)
# Uncomment when ready to send SMS confirmations
# Sign up at https://www.twilio.com to get credentials
# TWILIO_ACCOUNT_SID=your_account_sid_here
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_PHONE_NUMBER=+1234567890

# Zapier Webhook — automatic PDF quote generation (Phase 1B async)
# Trigger quote template when booking is submitted
# Create a Zapier webhook at https://zapier.com/app/zaps
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxx/yyy

# ──────────────────────────────────────────────────────────────
# Google Calendar Integration (Phase 2A)
# ──────────────────────────────────────────────────────────────

# Google Calendar — real-time availability with service account
# 1. Create a Google Cloud Project at https://console.cloud.google.com
# 2. Enable Google Calendar API
# 3. Create a Service Account and download JSON credentials
# 4. Share your calendar with the service account email
# 5. Fill in the values below:

# Google Cloud Project ID (from your JSON credentials file)
GOOGLE_CALENDAR_PROJECT_ID=your_project_id

# Service account private key (from your JSON credentials file)
# Replace newlines with \n in the JSON string
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# Service account email (from your JSON credentials file)
# Format: service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_CALENDAR_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com

# Raz's Google Calendar ID
# This is the calendar you want to fetch availability from
# Format: raz@funloading360.co.uk or the calendar's unique ID
GOOGLE_CALENDAR_CALENDAR_ID=raz@funloading360.co.uk

# ──────────────────────────────────────────────────────────────
# Stripe Payment Processing (Phase 2A)
# ──────────────────────────────────────────────────────────────

# Stripe — 15% deposit collection for photo booth bookings
# 1. Sign up at https://stripe.com
# 2. Get your API keys from https://dashboard.stripe.com/apikeys
# 3. Create a webhook endpoint at https://dashboard.stripe.com/webhooks
#    Webhook URL: https://your-domain.com/api/webhooks/stripe

# Stripe public key (used on the frontend for payment form)
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_public_key_here

# Stripe secret key (used on the backend, never expose to frontend)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe webhook signing secret (for verifying webhook authenticity)
# Get from https://dashboard.stripe.com/webhooks (click on your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
